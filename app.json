{
    "expo": {
        "name": "Webview di Informatica per Tutti",
        "slug": "webview-informatica-per-tutti",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icons/icon.png",
        "scheme": "webview",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "splash": {
            "image": "./assets/images/splash-screen.png",
            "resizeMode": "contain",
            "backgroundColor": "#002050",
            "imageWidth": 449,
            "dark": {
                "image": "./assets/images/splash-screen.png",
                "backgroundColor": "#1c1c1e"
            }
        },
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/icons/adaptive-icon.png",
                "backgroundColor": "#002050"
            }
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/icons/favicon.png"
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/images/splash-screen.png",
                    "imageWidth": 449,
                    "resizeMode": "contain",
                    "backgroundColor": "#002050",
                    "dark": {
                        "image": "./assets/images/splash-screen.png",
                        "backgroundColor": "#002050"
                    }
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}
